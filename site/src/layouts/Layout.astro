---
import Sidebar from '../components/Sidebar.astro';
import type { Post } from '../lib/posts';

interface Props {
  title: string;
  sidebarMonths?: string[];       // all months for archive
  calendarMonths?: string[];      // last 2 months for mini-calendars
  postsIndex?: Record<string, Post[]>; // month -> posts, for calendar dots
}

const { title, sidebarMonths = [], calendarMonths = [], postsIndex = {} } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: Georgia, 'Times New Roman', serif;
      background: #fafaf8;
      color: #1a1a1a;
      min-height: 100vh;
    }

    header {
      background: #1a1a1a;
      color: #fafaf8;
      padding: 0.75rem 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    header a {
      color: inherit;
      text-decoration: none;
      font-size: 1.1rem;
      font-weight: bold;
      letter-spacing: 0.02em;
    }

    .layout {
      display: grid;
      grid-template-columns: 260px 1fr;
      min-height: calc(100vh - 48px);
      max-width: 1400px;
      margin: 0 auto;
    }

    aside {
      border-right: 1px solid #e0e0d8;
      padding: 1.5rem 1rem;
      background: #f5f5f0;
    }

    main {
      padding: 2rem 2.5rem;
    }

    @media (max-width: 768px) {
      .layout { grid-template-columns: 1fr; }
      aside { border-right: none; border-bottom: 1px solid #e0e0d8; }
    }
  </style>
</head>
<body>
  <header>
    <a href="/">@gaperton_tech</a>
  </header>
  <div class="layout">
    <aside>
      <Sidebar months={sidebarMonths} calendarMonths={calendarMonths} postsIndex={postsIndex} />
    </aside>
    <main>
      <slot />
    </main>
  </div>
</body>
</html>
