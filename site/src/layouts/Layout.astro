---
import Sidebar from '../components/Sidebar.astro';
import type { Post } from '../lib/posts';

interface Props {
  title: string;
  sidebarMonths?: string[];
  currentMonth?: string;
  postsIndex?: Record<string, Post[]>;
}

const { title, sidebarMonths = [], currentMonth = '', postsIndex = {} } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: Georgia, 'Times New Roman', serif;
      background: #f7f7f4;
      color: #1a1a1a;
      min-height: 100vh;
    }

    header {
      background: #111827;
      color: #f9fafb;
      padding: 0 2rem;
      height: 52px;
      display: flex;
      align-items: center;
      gap: 1.5rem;
      border-bottom: 1px solid #1f2937;
    }

    header a.brand {
      color: #f9fafb;
      text-decoration: none;
      font-size: 1rem;
      font-weight: 700;
      font-family: ui-monospace, monospace;
      letter-spacing: 0.02em;
    }

    header .tagline {
      font-size: 0.8rem;
      color: #6b7280;
      font-family: ui-sans-serif, sans-serif;
    }

    .layout {
      display: grid;
      grid-template-columns: 240px 1fr;
      min-height: calc(100vh - 52px);
      max-width: 1440px;
      margin: 0 auto;
    }

    aside {
      border-right: 1px solid #e5e5dc;
      padding: 1.25rem 1rem 2rem;
      background: #f2f2ec;
      position: sticky;
      top: 0;
      height: calc(100vh - 52px);
      overflow-y: auto;
    }

    main {
      padding: 0.75rem 2rem 3rem;
      min-width: 0;
    }

    @media (max-width: 768px) {
      .layout { grid-template-columns: 1fr; }
      aside {
        position: static;
        height: auto;
        border-right: none;
        border-bottom: 1px solid #e5e5dc;
      }
    }
  </style>
</head>
<body>
  <header>
    <a href="/" class="brand">@gaperton_tech</a>
    <span class="tagline">Telegram channel archive</span>
  </header>
  <div class="layout">
    <aside>
      <Sidebar months={sidebarMonths} currentMonth={currentMonth} postsIndex={postsIndex} />
    </aside>
    <main>
      <slot />
    </main>
  </div>
</body>
</html>
