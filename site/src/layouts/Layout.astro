---
import Sidebar from '../components/Sidebar.astro';
import type { Post } from '../lib/posts';

interface Props {
  title: string;
  sidebarMonths?: string[];
  currentMonth?: string;
  postsIndex?: Record<string, Post[]>;
}

const { title, sidebarMonths = [], currentMonth = '', postsIndex = {} } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body { height: 100%; overflow: hidden; }

    body {
      font-family: Georgia, 'Times New Roman', serif;
      background: #f7f7f4;
      color: #1a1a1a;
      display: flex;
      flex-direction: column;
    }

    header {
      background: #111827;
      color: #f9fafb;
      padding: 0 2rem;
      height: 48px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    header a.brand {
      color: #f9fafb;
      text-decoration: none;
      font-size: 1rem;
      font-weight: 700;
      font-family: ui-monospace, monospace;
      letter-spacing: 0.02em;
    }

    header .tagline {
      font-size: 0.8rem;
      color: #6b7280;
      font-family: ui-sans-serif, sans-serif;
    }

    .layout {
      flex: 1;
      overflow: hidden;
      display: grid;
      grid-template-columns: 220px 1fr;
    }

    aside {
      border-right: 1px solid #e5e5dc;
      padding: 1.25rem 1rem 2rem;
      background: #f2f2ec;
      overflow-y: auto;
    }

    main {
      overflow-y: auto;
      padding: 0.75rem 2rem 3rem;
      min-width: 0;
    }

    main:has(.day-layout) {
      padding: 0;
      overflow: hidden;
    }

    @media (max-width: 768px) {
      .layout { grid-template-columns: 1fr; }
      aside { height: auto; border-right: none; border-bottom: 1px solid #e5e5dc; }
    }
  </style>
</head>
<body>
  <header>
    <a href="/" class="brand">@gaperton_tech</a>
    <span class="tagline">Telegram channel archive</span>
  </header>
  <div class="layout">
    <aside>
      <Sidebar months={sidebarMonths} currentMonth={currentMonth} postsIndex={postsIndex} />
    </aside>
    <main>
      <slot />
    </main>
  </div>
</body>
</html>
