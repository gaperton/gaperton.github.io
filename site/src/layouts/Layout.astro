---
import Sidebar from '../components/Sidebar.astro';
import type { Post } from '../lib/posts';

interface Props {
  title: string;
  sidebarMonths?: string[];
  currentMonth?: string;
  currentDay?: string;
  firstDayByMonth?: Record<string, string>;
  postsIndex?: Record<string, Post[]>;
}

const { title, sidebarMonths = [], currentMonth = '', currentDay = '', firstDayByMonth = {}, postsIndex = {} } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body { height: 100%; overflow: hidden; }

    /* Dark scrollbars */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #334155; }
    * { scrollbar-color: #1e293b transparent; scrollbar-width: thin; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      background: #0f172a;
      color: #e2e8f0;
      display: flex;
      flex-direction: column;
    }

    header {
      background: #020617;
      color: #e2e8f0;
      padding: 0 2rem;
      height: 48px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      gap: 1.5rem;
      border-bottom: 1px solid #1e293b;
    }

    header a.brand {
      color: #e2e8f0;
      text-decoration: none;
      font-size: 1rem;
      font-weight: 700;
      font-family: ui-monospace, monospace;
      letter-spacing: 0.02em;
    }

    header .tagline {
      font-size: 0.8rem;
      color: #475569;
      font-family: ui-sans-serif, sans-serif;
    }

    .layout {
      flex: 1;
      overflow: hidden;
      display: grid;
      grid-template-columns: 220px 1fr;
    }

    aside {
      border-right: 1px solid #1e293b;
      padding: 1.25rem 1rem 2rem;
      background: #0a0f1e;
      overflow-y: auto;
    }

    main {
      overflow-y: auto;
      padding: 0.75rem 2rem 3rem;
      min-width: 0;
    }

    main:has(.day-layout) {
      padding: 0;
      overflow: hidden;
    }

    @media (max-width: 768px) {
      .layout { grid-template-columns: 1fr; }
      aside { height: auto; border-right: none; border-bottom: 1px solid #1e293b; }
    }
  </style>
</head>
<body>
  <header>
    <a href="/" class="brand">@gaperton_tech</a>
    <span class="tagline">Telegram channel archive</span>
  </header>
  <div class="layout">
    <aside>
      <Sidebar months={sidebarMonths} currentMonth={currentMonth} currentDay={currentDay} firstDayByMonth={firstDayByMonth} postsIndex={postsIndex} />
    </aside>
    <main>
      <slot />
    </main>
  </div>
</body>
</html>
