---
import MiniCalendar from './MiniCalendar.astro';
import type { Post } from '../lib/posts';

interface Props {
  months: string[];
  currentMonth: string;
  currentDay?: string;
  firstDayByMonth?: Record<string, string>;
  postsIndex: Record<string, Post[]>;
}

const { months, currentMonth, currentDay = '', firstDayByMonth = {}, postsIndex } = Astro.props;

const idx = months.indexOf(currentMonth);
const prevMonth = idx > 0 ? months[idx - 1] : null;
const nextMonth = idx < months.length - 1 ? months[idx + 1] : null;

const byYear: Record<string, string[]> = {};
for (const m of [...months].reverse()) {
  const y = m.slice(0, 4);
  if (!byYear[y]) byYear[y] = [];
  byYear[y].push(m);
}
const years = Object.keys(byYear).sort().reverse();

function monthLabel(m: string) {
  const [y, mo] = m.split('-').map(Number);
  return new Date(y, mo - 1, 1).toLocaleString('en-GB', { month: 'long' });
}
---
<div class="sidebar">
  <MiniCalendar
    month={currentMonth}
    posts={postsIndex[currentMonth] ?? []}
    prevMonth={prevMonth}
    nextMonth={nextMonth}
    currentDay={currentDay}
  />

  <div class="divider" />

  <nav class="archive">
    <div class="archive-title">Archive</div>
    {years.map(year => (
      <details open={currentMonth.startsWith(year)}>
        <summary class="year">{year}</summary>
        <ul>
          {byYear[year].map(m => (
            <li>
              <a href={`/${firstDayByMonth[m] ?? m}/`} class:list={[{ active: m === currentMonth }]}>{monthLabel(m)}</a>
            </li>
          ))}
        </ul>
      </details>
    ))}
  </nav>
</div>

<style>
  .sidebar { font-family: ui-sans-serif, sans-serif; }

  .divider {
    height: 1px;
    background: #1e293b;
    margin: 0.25rem 0 1rem;
  }

  .archive-title {
    font-size: 0.65rem;
    font-weight: 700;
    color: #334155;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  details { margin-bottom: 0.15rem; }

  summary.year {
    font-size: 0.82rem;
    font-weight: 600;
    color: #64748b;
    cursor: pointer;
    list-style: none;
    padding: 0.25rem 0;
    display: flex;
    align-items: center;
    user-select: none;
  }

  summary.year::before {
    content: '›';
    font-size: 0.9rem;
    color: #334155;
    transition: transform 0.15s;
    display: inline-block;
    width: 0.8rem;
  }

  details[open] summary.year::before { transform: rotate(90deg); }
  summary.year:hover { color: #94a3b8; }

  ul {
    list-style: none;
    padding-left: 1.1rem;
    margin: 0.1rem 0 0.4rem;
    border-left: 2px solid #1e293b;
  }

  li a {
    font-size: 0.8rem;
    color: #475569;
    text-decoration: none;
    display: block;
    padding: 2px 0 2px 0.5rem;
    border-radius: 3px;
  }

  li a:hover { color: #93c5fd; background: #1e293b; }
  li a.active { color: #60a5fa; font-weight: 600; }
</style>
