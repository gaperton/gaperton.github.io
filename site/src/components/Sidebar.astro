---
import MiniCalendar from './MiniCalendar.astro';
import type { Post } from '../lib/posts';

interface Props {
  months: string[];                     // all months, for archive
  calendarMonths: string[];             // last 2 months to show as calendars
  postsIndex: Record<string, Post[]>;   // month -> posts
}

const { months, calendarMonths, postsIndex } = Astro.props;

// Group months by year for the archive
const byYear: Record<string, string[]> = {};
for (const m of [...months].reverse()) {
  const y = m.slice(0, 4);
  if (!byYear[y]) byYear[y] = [];
  byYear[y].push(m);
}
const years = Object.keys(byYear).sort().reverse();

function monthLabel(m: string) {
  const [y, mo] = m.split('-').map(Number);
  return new Date(y, mo - 1, 1).toLocaleString('en-GB', { month: 'long' });
}
---
<div class="sidebar">
  {calendarMonths.map(m => (
    <MiniCalendar month={m} posts={postsIndex[m] ?? []} />
  ))}

  <nav class="archive">
    <div class="archive-title">Archive</div>
    {years.map(year => (
      <details open={year === years[0]}>
        <summary class="year">{year}</summary>
        <ul>
          {byYear[year].map(m => (
            <li>
              <a href={`/${m}/`}>{monthLabel(m)}</a>
            </li>
          ))}
        </ul>
      </details>
    ))}
  </nav>
</div>

<style>
  .sidebar { font-family: ui-sans-serif, sans-serif; }

  .archive { margin-top: 0.5rem; }

  .archive-title {
    font-size: 0.75rem;
    font-weight: 700;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
  }

  details { margin-bottom: 0.25rem; }

  summary.year {
    font-size: 0.85rem;
    font-weight: 600;
    color: #444;
    cursor: pointer;
    list-style: none;
    padding: 0.2rem 0;
  }

  summary.year::before {
    content: '▸ ';
    font-size: 0.7rem;
  }

  details[open] summary.year::before { content: '▾ '; }

  ul {
    list-style: none;
    padding-left: 1rem;
    margin: 0.2rem 0 0.4rem;
  }

  li a {
    font-size: 0.82rem;
    color: #555;
    text-decoration: none;
    display: block;
    padding: 1px 0;
  }

  li a:hover { color: #1a1a1a; text-decoration: underline; }
</style>
