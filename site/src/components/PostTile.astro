---
import type { Post } from '../lib/posts';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const href = `/${post.month}/${post.slug}/`;
const time = new Date(post.datetime).toLocaleTimeString('en-GB', {
  hour: '2-digit', minute: '2-digit',
});
---
<a href={href} class="tile">
  <div class="meta">
    <span class="time">{time}</span>
    {post.hasImages && <span class="dot green" title="has photo" />}
    {post.commentCount > 0 && <span class="comments">{post.commentCount}</span>}
  </div>
  <div class="body">
    {post.preview || <em class="empty">[ media ]</em>}
  </div>
</a>

<style>
  .tile {
    display: block;
    background: #fff;
    border: 1px solid #e8e8e0;
    border-radius: 8px;
    padding: 0.85rem 1rem;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    transition: box-shadow 0.12s, border-color 0.12s;
    break-inside: avoid;
  }

  .tile:hover {
    box-shadow: 0 3px 10px rgba(0,0,0,0.09);
    border-color: #bbb;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
  }

  .time {
    font-size: 0.72rem;
    font-weight: 700;
    color: #888;
    font-family: ui-monospace, monospace;
    letter-spacing: 0.04em;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot.green { background: #86efac; }

  .comments {
    font-size: 0.68rem;
    color: #93c5fd;
    font-family: ui-monospace, monospace;
    font-weight: 600;
  }

  .body {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #222;
    font-family: ui-sans-serif, system-ui, sans-serif;
  }

  .empty { color: #ccc; font-style: italic; }
</style>
