---
import type { Post } from '../lib/posts';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const href = `/${post.month}/${post.slug}/`;
const time = new Date(post.datetime).toLocaleTimeString('en-GB', {
  hour: '2-digit', minute: '2-digit',
});
---
<a href={href} class="tile">
  <div class="meta">
    <span class="time">{time}</span>
    {post.hasImages && <span class="badge img">📷</span>}
    {post.commentCount > 0 && <span class="badge">{post.commentCount} 💬</span>}
  </div>
  <div class="body">
    {post.preview || <em class="empty">[ media ]</em>}
  </div>
</a>

<style>
  .tile {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: #fff;
    border: 1px solid #e0e0d8;
    border-radius: 6px;
    padding: 1rem 1.1rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s, border-color 0.15s;
    height: 100%;
  }

  .tile:hover {
    box-shadow: 0 2px 8px rgba(0,0,0,0.10);
    border-color: #bbb;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: #888;
    font-family: ui-monospace, monospace;
  }

  .time { font-weight: 600; color: #555; }

  .badge {
    font-size: 0.72rem;
    background: #f0f0ea;
    border-radius: 4px;
    padding: 1px 5px;
  }

  .body {
    font-size: 1rem;
    line-height: 1.55;
    color: #222;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 8;
    -webkit-box-orient: vertical;
  }

  .empty { color: #aaa; }
</style>
