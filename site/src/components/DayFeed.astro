---
import type { PostDetail } from '../lib/posts';

interface Props {
  posts: PostDetail[];
  dayLabel: string;
  prevDay: string | null;
  prevDayLabel: string | null;
}

const { posts, dayLabel, prevDay, prevDayLabel } = Astro.props;

function fmtTime(datetime: string) {
  return new Date(datetime).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
}
---

<div class="feed-wrap">
  <div class="day-heading">{dayLabel}</div>

  <div class="posts-feed">
    {posts.map(post => (
      <article
        class="post-card"
        data-href={`/${post.month}/${post.slug}/`}
        data-time={fmtTime(post.datetime)}
        data-quote={post.replyQuote ?? ''}
        data-preview={post.bodyHtml.replace(/<[^>]+>/g, '').trim().slice(0, 400)}
        data-comments={post.comments.length}
        role="button"
        tabindex="0"
      >
        {post.replyQuote && (
          <div class="post-reply-quote">{post.replyQuote}</div>
        )}

        {post.images.length > 0 && (
          <div class="post-images">
            {post.images.map(src => (
              <a href={src} target="_blank" rel="noopener" onclick="event.stopPropagation()">
                <img src={src} loading="lazy" alt="" />
              </a>
            ))}
          </div>
        )}

        <div class="post-body" set:html={post.bodyHtml} />

        <div class="post-footer">
          <span class="post-time">{fmtTime(post.datetime)}</span>
          {post.comments.length > 0 && (
            <span class="comment-count">{post.comments.length} comments</span>
          )}
        </div>
      </article>
    ))}
  </div>

  {prevDay && (
    <a class="prev-nav" href={`/${prevDay}/`}>← {prevDayLabel}</a>
  )}
</div>

<!-- Modal dialog -->
<dialog id="post-modal">
  <div class="modal-header">
    <button class="modal-close" id="modal-close">✕</button>
  </div>
  <div class="modal-body" id="modal-body">
    <p class="modal-loading">Loading…</p>
  </div>
</dialog>

<script>
  const modal = document.getElementById('post-modal') as HTMLDialogElement;
  const modalBody = document.getElementById('modal-body')!;
  const modalClose = document.getElementById('modal-close')!;
  const injectedStyles = new Set<string>();

  function buildModalHeader(card: HTMLElement): string {
    const time = card.dataset.time ?? '';
    const quote = card.dataset.quote ?? '';
    const preview = card.dataset.preview ?? '';
    const count = card.dataset.comments ?? '0';

    const quotePart = quote
      ? `<div class="modal-reply-quote">${quote}</div>`
      : '';
    const previewPart = preview
      ? `<div class="modal-post-preview">${preview}</div>`
      : '';
    const footer = `<div class="modal-post-footer">
      <span class="modal-time">${time}</span>
      <span class="modal-comment-count">${count} comment${count !== '1' ? 's' : ''}</span>
    </div>`;

    return `<div class="modal-post-card">${quotePart}${previewPart}${footer}</div>`;
  }

  async function openPost(card: HTMLElement) {
    const href = card.dataset.href!;
    const header = buildModalHeader(card);

    modalBody.innerHTML = header + '<p class="modal-loading">Loading…</p>';
    modal.showModal();

    const res = await fetch(href);
    const html = await res.text();
    const doc = new DOMParser().parseFromString(html, 'text/html');

    doc.querySelectorAll('head style').forEach(s => {
      if (!injectedStyles.has(s.textContent!)) {
        injectedStyles.add(s.textContent!);
        const el = document.createElement('style');
        el.textContent = s.textContent;
        document.head.appendChild(el);
      }
    });

    const comments = doc.querySelector('section.comments');
    modalBody.innerHTML = header + (comments?.outerHTML ?? '');
    modalBody.scrollTop = 0;
  }

  // Click card to open modal
  document.querySelectorAll<HTMLElement>('.post-card').forEach(card => {
    card.addEventListener('click', () => openPost(card));
    card.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') openPost(card);
    });
  });

  // Close on button or backdrop click
  modalClose.addEventListener('click', () => modal.close());
  modal.addEventListener('click', e => {
    if (e.target === modal) modal.close();
  });
</script>

<style>
  .feed-wrap {
    height: 100%;
    overflow-y: auto;
    padding: 1rem 2rem 2rem;
    max-width: 860px;
  }

  .day-heading {
    font-size: 1.1rem;
    font-weight: 600;
    color: #f1f5f9;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #3b82f6;
    display: inline-block;
  }

  .posts-feed {
    display: flex;
    flex-direction: column;
  }

  .post-card {
    padding: 1.25rem 0;
    border-bottom: 1px solid #1e293b;
    cursor: pointer;
    outline: none;
    transition: opacity 0.12s;
  }

  .post-card:last-child { border-bottom: none; }
  .post-card:hover { opacity: 0.85; }
  .post-card:focus-visible { outline: 1px solid #3b82f6; border-radius: 4px; }

  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.65rem;
  }

  .post-time {
    font-size: 0.7rem;
    font-weight: 700;
    color: #2d3f55;
    font-family: ui-monospace, monospace;
    letter-spacing: 0.04em;
  }

  .comment-count {
    font-size: 0.7rem;
    color: #2d3f55;
  }

  .post-reply-quote {
    border-left: 3px solid #1e40af;
    background: #0f1e3a;
    border-radius: 0 6px 6px 0;
    padding: 0.35rem 0.7rem;
    margin-bottom: 0.6rem;
    color: #6b94c4;
    font-size: 0.85em;
    white-space: pre-wrap;
  }

  .post-images {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.6rem;
  }

  .post-images img {
    max-width: min(560px, 100%);
    max-height: 400px;
    object-fit: contain;
    border-radius: 6px;
    border: 1px solid #1e293b;
    background: #0a0f1e;
  }

  .post-body {
    font-size: 0.925rem;
    line-height: 1.65;
    color: #94a3b8;
  }

  .post-body :global(p) { margin-bottom: 0.7em; }
  .post-body :global(p:last-child) { margin-bottom: 0; }
  .post-body :global(a) { color: #60a5fa; }
  .post-body :global(strong) { color: #cbd5e1; }
  .post-body :global(blockquote) {
    border-left: 3px solid #1e40af;
    background: #0f1e3a;
    border-radius: 0 6px 6px 0;
    padding: 0.4rem 0.8rem;
    margin: 0.5em 0;
    color: #6b94c4;
    font-size: 0.95em;
  }
  .post-body :global(blockquote p) { margin-bottom: 0; }
  .post-body :global(code) {
    font-family: ui-monospace, monospace;
    font-size: 0.85em;
    background: #0f172a;
    color: #7dd3fc;
    padding: 1px 4px;
    border-radius: 3px;
  }
  .post-body :global(pre) {
    background: #0a0f1e;
    color: #e2e8f0;
    padding: 0.85rem;
    border-radius: 6px;
    overflow-x: auto;
    font-size: 0.82em;
    margin: 0.6em 0;
    border: 1px solid #1e293b;
  }

  .prev-nav {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: 0.85rem;
    color: #3b82f6;
    text-decoration: none;
    font-weight: 500;
  }
  .prev-nav:hover { color: #60a5fa; }

  /* Modal */
  dialog {
    border: none;
    border-radius: 12px;
    background: #0f172a;
    color: #e2e8f0;
    max-width: 780px;
    width: 90vw;
    max-height: 85vh;
    overflow: hidden;
    padding: 0;
    box-shadow: 0 25px 60px rgba(0,0,0,0.6);
  }

  dialog::backdrop {
    background: rgba(2, 6, 23, 0.8);
    backdrop-filter: blur(4px);
  }

  .modal-header {
    display: flex;
    justify-content: flex-end;
    padding: 0.6rem 0.75rem 0;
    position: sticky;
    top: 0;
    background: #0f172a;
    z-index: 1;
  }

  .modal-close {
    background: none;
    border: none;
    color: #475569;
    font-size: 1rem;
    cursor: pointer;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .modal-close:hover { background: #1e293b; color: #94a3b8; }

  .modal-body {
    padding: 0.5rem 1.75rem 1.75rem;
    overflow-y: auto;
    max-height: calc(85vh - 48px);
  }

  .modal-loading {
    color: #334155;
    font-size: 0.9rem;
    padding: 1rem 0;
  }

  :global(.modal-post-card) {
    padding-bottom: 1rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid #1e293b;
  }

  :global(.modal-reply-quote) {
    border-left: 3px solid #1e40af;
    background: #0f1628;
    border-radius: 0 5px 5px 0;
    padding: 0.3rem 0.65rem;
    margin-bottom: 0.6rem;
    color: #4a6fa5;
    font-size: 0.83em;
    white-space: pre-wrap;
  }

  :global(.modal-post-preview) {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #94a3b8;
    margin-bottom: 0.75rem;
    white-space: pre-wrap;
  }

  :global(.modal-post-footer) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.5rem;
    border-top: 1px solid #1e293b;
  }

  :global(.modal-time) {
    font-size: 0.72rem;
    font-weight: 700;
    color: #334155;
    font-family: ui-monospace, monospace;
    letter-spacing: 0.04em;
  }

  :global(.modal-comment-count) {
    font-size: 0.7rem;
    color: #334155;
  }
</style>
