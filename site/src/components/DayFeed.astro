---
import type { PostDetail } from '../lib/posts';

interface Props {
  posts: PostDetail[];
  dayLabel: string;
  prevDay: string | null;
  prevDayLabel: string | null;
}

const { posts, dayLabel, prevDay, prevDayLabel } = Astro.props;

function fmtTime(datetime: string) {
  return new Date(datetime).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
}
---

<div class="day-layout">
  <div class="posts-col">
    <div class="day-heading">{dayLabel}</div>

    <div class="posts-feed">
      {posts.map(post => (
        <article class="post-card" id={`post-${post.id}`}>
          <div class="post-meta">
            <span class="post-time">{fmtTime(post.datetime)}</span>
          </div>

          {post.replyQuote && (
            <div class="post-reply-quote">{post.replyQuote}</div>
          )}

          {post.images.length > 0 && (
            <div class="post-images">
              {post.images.map(src => (
                <a href={src} target="_blank" rel="noopener">
                  <img src={src} loading="lazy" alt="" />
                </a>
              ))}
            </div>
          )}

          <div class="post-body" set:html={post.bodyHtml} />

          {post.comments.length > 0 && (
            <button class="comments-btn" data-href={`/${post.month}/${post.slug}/`}>
              {post.comments.length} comment{post.comments.length !== 1 ? 's' : ''} →
            </button>
          )}
        </article>
      ))}
    </div>

    {prevDay && (
      <a class="prev-nav" href={`/${prevDay}/`}>← {prevDayLabel}</a>
    )}
  </div>

  <div class="comments-col" id="comments-col">
    <p class="empty-hint">← open comments</p>
  </div>
</div>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.comments-btn');
  const col = document.getElementById('comments-col')!;
  const injectedStyles = new Set<string>();

  async function loadComments(btn: HTMLButtonElement) {
    btns.forEach(b => b.classList.remove('is-active'));
    btn.classList.add('is-active');
    col.innerHTML = '<p style="padding:1rem;color:#475569;font-family:sans-serif">Loading…</p>';

    const res = await fetch(btn.dataset.href!);
    const html = await res.text();
    const doc = new DOMParser().parseFromString(html, 'text/html');

    doc.querySelectorAll('head style').forEach(s => {
      if (!injectedStyles.has(s.textContent!)) {
        injectedStyles.add(s.textContent!);
        const el = document.createElement('style');
        el.textContent = s.textContent;
        document.head.appendChild(el);
      }
    });

    const comments = doc.querySelector('section.comments');
    col.innerHTML = comments?.outerHTML ?? '<p style="padding:1rem;color:#475569;font-family:sans-serif">No comments</p>';
    col.scrollTop = 0;
  }

  btns.forEach(b => b.addEventListener('click', () => loadComments(b)));
  if (btns[0]) loadComments(btns[0]);
</script>

<style>
  .day-layout {
    display: grid;
    grid-template-columns: 54% 46%;
    height: 100%;
    overflow: hidden;
  }

  .posts-col {
    overflow-y: auto;
    padding: 1rem 1.75rem 2rem;
    border-right: 1px solid #1e293b;
  }

  .day-heading {
    font-size: 1.1rem;
    font-weight: 600;
    color: #f1f5f9;
    font-family: ui-sans-serif, sans-serif;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #3b82f6;
    display: inline-block;
  }

  .posts-feed {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .post-card {
    border-bottom: 1px solid #1e293b;
    padding-bottom: 2rem;
  }

  .post-card:last-child { border-bottom: none; }

  .post-meta { margin-bottom: 0.75rem; }

  .post-time {
    font-size: 0.72rem;
    font-weight: 700;
    color: #475569;
    font-family: ui-monospace, monospace;
    letter-spacing: 0.04em;
  }

  .post-reply-quote {
    border-left: 3px solid #1e40af;
    background: #0f2547;
    border-radius: 0 6px 6px 0;
    padding: 0.4rem 0.75rem;
    margin-bottom: 0.75rem;
    color: #93c5fd;
    font-size: 0.88em;
    white-space: pre-wrap;
    font-family: ui-sans-serif, sans-serif;
  }

  .post-images {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .post-images img {
    max-width: min(480px, 100%);
    max-height: 480px;
    object-fit: contain;
    border-radius: 6px;
    border: 1px solid #1e293b;
    background: #0a0f1e;
  }

  .post-body {
    font-size: 0.975rem;
    line-height: 1.72;
    color: #cbd5e1;
  }

  .post-body :global(p) { margin-bottom: 0.85em; }
  .post-body :global(p:last-child) { margin-bottom: 0; }
  .post-body :global(a) { color: #60a5fa; }
  .post-body :global(a:hover) { color: #93c5fd; }
  .post-body :global(strong) { font-weight: 700; color: #e2e8f0; }
  .post-body :global(em) { font-style: italic; color: #94a3b8; }
  .post-body :global(code) {
    font-family: ui-monospace, monospace;
    font-size: 0.88em;
    background: #1e293b;
    color: #93c5fd;
    padding: 1px 5px;
    border-radius: 3px;
  }
  .post-body :global(pre) {
    background: #0a0f1e;
    color: #e2e8f0;
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    font-size: 0.85em;
    margin: 0.75em 0;
    border: 1px solid #1e293b;
  }
  .post-body :global(blockquote) {
    border-left: 3px solid #1e40af;
    background: #0f2547;
    border-radius: 0 6px 6px 0;
    padding: 0.5rem 0.9rem;
    margin: 0.75em 0;
    color: #93c5fd;
    font-size: 0.95em;
  }
  .post-body :global(blockquote p) { margin-bottom: 0; }

  .comments-btn {
    display: inline-block;
    margin-top: 0.85rem;
    font-size: 0.8rem;
    font-family: ui-sans-serif, sans-serif;
    font-weight: 500;
    color: #3b82f6;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .comments-btn:hover { color: #60a5fa; }
  .comments-btn.is-active { color: #93c5fd; font-weight: 700; }

  .prev-nav {
    display: inline-block;
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: #3b82f6;
    text-decoration: none;
    font-family: ui-sans-serif, sans-serif;
    font-weight: 500;
  }
  .prev-nav:hover { color: #60a5fa; }

  .comments-col {
    overflow-y: auto;
    padding: 1rem 1.5rem 2rem;
    background: #0a0f1e;
  }

  .empty-hint {
    color: #1e293b;
    font-size: 0.85rem;
    font-family: ui-sans-serif, sans-serif;
    margin-top: 2rem;
    text-align: center;
  }
</style>
