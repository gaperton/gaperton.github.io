---
import type { Post } from '../lib/posts';

interface Props {
  month: string;
  posts: Post[];
  prevMonth?: string | null;
  nextMonth?: string | null;
}

const { month, posts, prevMonth = null, nextMonth = null } = Astro.props;

const [year, mon] = month.split('-').map(Number);
const daysInMonth = new Date(year, mon, 0).getDate();
const firstDow = new Date(year, mon - 1, 1).getDay();
const offset = (firstDow + 6) % 7;

const activeDays = new Set(posts.map(p => p.date));

const label = new Date(year, mon - 1, 1).toLocaleString('en-GB', { month: 'long', year: 'numeric' });
---
<div class="cal">
  <div class="cal-header">
    {prevMonth
      ? <a href={`/${prevMonth}/`} class="nav" title="Previous month">‹</a>
      : <span class="nav disabled">‹</span>
    }
    <span class="cal-title">{label}</span>
    {nextMonth
      ? <a href={`/${nextMonth}/`} class="nav" title="Next month">›</a>
      : <span class="nav disabled">›</span>
    }
  </div>
  <div class="cal-grid">
    {['Mo','Tu','We','Th','Fr','Sa','Su'].map(d => (
      <span class="dow">{d}</span>
    ))}
    {Array.from({ length: offset }, (_, i) => (
      <span key={`empty-${i}`} />
    ))}
    {Array.from({ length: daysInMonth }, (_, i) => {
      const day = i + 1;
      const dateStr = `${month}-${String(day).padStart(2, '0')}`;
      return activeDays.has(dateStr)
        ? <a href={`/${dateStr}/`} class="day active">{day}</a>
        : <span class="day">{day}</span>;
    })}
  </div>
</div>

<style>
  .cal { margin-bottom: 1rem; }

  .cal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
    gap: 0.25rem;
  }

  .cal-title {
    font-size: 0.72rem;
    font-weight: 700;
    color: #555;
    font-family: ui-sans-serif, sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    flex: 1;
    text-align: center;
  }

  .nav {
    font-size: 1rem;
    line-height: 1;
    color: #888;
    text-decoration: none;
    padding: 1px 4px;
    border-radius: 3px;
    font-weight: 500;
    flex-shrink: 0;
  }

  a.nav:hover {
    background: #e8eeff;
    color: #3b5bdb;
  }

  .nav.disabled {
    color: #ddd;
    cursor: default;
  }

  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 1px;
    font-size: 0.72rem;
    font-family: ui-monospace, monospace;
  }

  .dow {
    text-align: center;
    color: #bbb;
    padding: 2px 0 4px;
    font-size: 0.62rem;
    font-family: ui-sans-serif, sans-serif;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .day {
    text-align: center;
    padding: 3px 1px;
    border-radius: 4px;
    color: #ccc;
    line-height: 1.4;
  }

  a.day.active {
    color: #1e3a8a;
    text-decoration: none;
    font-weight: 700;
    background: #dbeafe;
  }

  a.day.active:hover {
    background: #3b5bdb;
    color: #fff;
  }
</style>
