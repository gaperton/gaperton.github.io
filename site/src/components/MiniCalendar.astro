---
import type { Post } from '../lib/posts';

interface Props {
  month: string;
  posts: Post[];
}

const { month, posts } = Astro.props;

const [year, mon] = month.split('-').map(Number);
const daysInMonth = new Date(year, mon, 0).getDate();
const firstDow = new Date(year, mon - 1, 1).getDay();
const offset = (firstDow + 6) % 7;

const activeDays = new Set(posts.map(p => p.date));

const label = new Date(year, mon - 1, 1).toLocaleString('en-GB', { month: 'long', year: 'numeric' });
---
<div class="cal">
  <div class="cal-title">{label}</div>
  <div class="cal-grid">
    {['Mo','Tu','We','Th','Fr','Sa','Su'].map(d => (
      <span class="dow">{d}</span>
    ))}
    {Array.from({ length: offset }, (_, i) => (
      <span key={`empty-${i}`} />
    ))}
    {Array.from({ length: daysInMonth }, (_, i) => {
      const day = i + 1;
      const dateStr = `${month}-${String(day).padStart(2, '0')}`;
      return activeDays.has(dateStr)
        ? <a href={`/${dateStr}/`} class="day active">{day}</a>
        : <span class="day">{day}</span>;
    })}
  </div>
</div>

<style>
  .cal { margin-bottom: 1.5rem; }

  .cal-title {
    font-size: 0.72rem;
    font-weight: 700;
    color: #666;
    margin-bottom: 0.5rem;
    font-family: ui-sans-serif, sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 1px;
    font-size: 0.72rem;
    font-family: ui-monospace, monospace;
  }

  .dow {
    text-align: center;
    color: #bbb;
    padding: 2px 0 4px;
    font-size: 0.62rem;
    font-family: ui-sans-serif, sans-serif;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .day {
    text-align: center;
    padding: 3px 1px;
    border-radius: 4px;
    color: #ccc;
    line-height: 1.4;
  }

  a.day.active {
    color: #1e3a8a;
    text-decoration: none;
    font-weight: 700;
    background: #dbeafe;
    position: relative;
  }

  a.day.active:hover {
    background: #3b5bdb;
    color: #fff;
  }
</style>
