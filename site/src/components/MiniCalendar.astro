---
import type { Post } from '../lib/posts';

interface Props {
  month: string;
  posts: Post[];
  prevMonth?: string | null;
  nextMonth?: string | null;
  currentDay?: string;
}

const { month, posts, prevMonth = null, nextMonth = null, currentDay = '' } = Astro.props;

const [year, mon] = month.split('-').map(Number);
const daysInMonth = new Date(year, mon, 0).getDate();
const firstDow = new Date(year, mon - 1, 1).getDay();
const offset = (firstDow + 6) % 7;
const activeDays = new Set(posts.map(p => p.date));
const label = new Date(year, mon - 1, 1).toLocaleString('en-GB', { month: 'long', year: 'numeric' });
---
<div class="cal">
  <div class="cal-header">
    {prevMonth
      ? <a href={`/${prevMonth}/`} class="nav" title="Previous month">‹</a>
      : <span class="nav disabled">‹</span>
    }
    <span class="cal-title">{label}</span>
    {nextMonth
      ? <a href={`/${nextMonth}/`} class="nav" title="Next month">›</a>
      : <span class="nav disabled">›</span>
    }
  </div>
  <div class="cal-grid">
    {['Mo','Tu','We','Th','Fr','Sa','Su'].map(d => (
      <span class="dow">{d}</span>
    ))}
    {Array.from({ length: offset }, (_, i) => <span key={`e${i}`} />)}
    {Array.from({ length: daysInMonth }, (_, i) => {
      const day = i + 1;
      const dateStr = `${month}-${String(day).padStart(2, '0')}`;
      const isActive = activeDays.has(dateStr);
      const isSelected = dateStr === currentDay;
      return isActive
        ? <a href={`/${dateStr}/`} class:list={['day', 'active', { selected: isSelected }]}>{day}</a>
        : <span class="day">{day}</span>;
    })}
  </div>
</div>

<style>
  .cal { margin-bottom: 1.5rem; }

  .cal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .cal-title {
    font-size: 0.72rem;
    font-weight: 700;
    color: #94a3b8;
    font-family: ui-sans-serif, sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    flex: 1;
    text-align: center;
  }

  .nav {
    font-size: 1rem;
    color: #475569;
    text-decoration: none;
    padding: 1px 5px;
    border-radius: 3px;
  }

  a.nav:hover { background: #1e293b; color: #93c5fd; }
  .nav.disabled { color: #1e293b; cursor: default; }

  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 1px;
    font-size: 0.72rem;
    font-family: ui-monospace, monospace;
  }

  .dow {
    text-align: center;
    color: #334155;
    padding: 2px 0 4px;
    font-size: 0.62rem;
    font-family: ui-sans-serif, sans-serif;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .day {
    text-align: center;
    padding: 3px 1px;
    border-radius: 4px;
    color: #334155;
    line-height: 1.4;
  }

  a.day.active {
    color: #93c5fd;
    text-decoration: none;
    font-weight: 700;
    background: #1e3a5f;
  }

  a.day.active:hover {
    background: #3b82f6;
    color: #fff;
  }

  a.day.selected {
    background: #3b82f6;
    color: #fff;
    box-shadow: 0 0 0 2px #60a5fa;
  }
</style>
