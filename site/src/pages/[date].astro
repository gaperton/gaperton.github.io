---
import Layout from '../layouts/Layout.astro';
import DayFeed from '../components/DayFeed.astro';
import { getAllDays, getPostsForDay, getPost } from '../lib/posts';
import { buildSidebarProps } from '../lib/sidebarProps';

export async function getStaticPaths() {
  const days = getAllDays();
  return days.map((date, i) => ({
    params: { date },
    props: { prevDay: days[i + 1] ?? null },
  }));
}

const { date } = Astro.params;
const { prevDay } = Astro.props;
const sidebar = buildSidebarProps(date.slice(0, 7));

const lightPosts = getPostsForDay(date);
const posts = lightPosts.map(p => getPost(p.month, p.slug));

function fmtDay(d: string) {
  return new Date(d + 'T00:00:00').toLocaleDateString('en-GB', {
    weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
  });
}
---
<Layout title={`${fmtDay(date)} — @gaperton_tech`} {...sidebar}>
  <DayFeed
    posts={posts}
    dayLabel={fmtDay(date)}
    prevDay={prevDay}
    prevDayLabel={prevDay ? fmtDay(prevDay) : null}
  />
</Layout>
