---
import Layout from '../layouts/Layout.astro';
import PostTile from '../components/PostTile.astro';
import { getAllDays, getPostsForDay } from '../lib/posts';
import { buildSidebarProps } from '../lib/sidebarProps';

export async function getStaticPaths() {
  const days = getAllDays();
  return days.map((date, i) => ({
    params: { date },
    props: { prevDay: days[i + 1] ?? null },
  }));
}

const { date } = Astro.params;
const { prevDay } = Astro.props;
const posts = getPostsForDay(date);
const sidebar = buildSidebarProps(date.slice(0, 7));

const dayLabel = new Date(date + 'T00:00:00').toLocaleDateString('en-GB', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
});
---
<Layout title={`${dayLabel} — @gaperton_tech`} {...sidebar}>
  <h1 class="day-heading">{dayLabel}</h1>

  <div class="tile-grid">
    {posts.map(post => (
      <PostTile post={post} />
    ))}
  </div>

  {prevDay && (
    <div class="prev-nav">
      <a href={`/${prevDay}/`}>
        ← {new Date(prevDay + 'T00:00:00').toLocaleDateString('en-GB', {
          weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
        })}
      </a>
    </div>
  )}
</Layout>

<style>
  .day-heading {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
    color: #111;
    font-family: ui-sans-serif, sans-serif;
    padding-bottom: 0.6rem;
    border-bottom: 2px solid #3b5bdb;
    display: inline-block;
  }

  .tile-grid {
    columns: 3 260px;
    column-gap: 0.85rem;
    margin-bottom: 2.5rem;
  }

  .tile-grid > :global(*) {
    margin-bottom: 0.85rem;
  }

  .prev-nav {
    margin-top: 0.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid #e5e5dc;
  }

  .prev-nav a {
    font-size: 0.88rem;
    color: #3b5bdb;
    text-decoration: none;
    font-family: ui-sans-serif, sans-serif;
    font-weight: 500;
  }

  .prev-nav a:hover { text-decoration: underline; }
</style>
