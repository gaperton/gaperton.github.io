---
import Layout from '../../layouts/Layout.astro';
import { getMonths, getPostSlugsForMonth, getPost } from '../../lib/posts';
import { buildSidebarProps } from '../../lib/sidebarProps';

export async function getStaticPaths() {
  const paths = [];
  for (const month of getMonths()) {
    for (const slug of getPostSlugsForMonth(month)) {
      paths.push({ params: { month, slug } });
    }
  }
  return paths;
}

const { month, slug } = Astro.params;
const post = getPost(month, slug);
const sidebar = buildSidebarProps(month, post.date);

const dayHref = `/${post.date}/`;
const monthHref = `/${month}/`;
const dayLabel = new Date(post.date + 'T00:00:00').toLocaleDateString('en-GB', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
});
---
<Layout title={`Post #${post.id} — @gaperton_tech`} {...sidebar}>
  <nav class="breadcrumb">
    <a href="/">Home</a> /
    <a href={monthHref}>{month}</a> /
    <a href={dayHref}>{dayLabel}</a>
  </nav>

  <article class="post">
    {post.images.length > 0 && (
      <div class="image-gallery">
        {post.images.map(src => (
          <a href={src} target="_blank" rel="noopener">
            <img src={src} loading="lazy" alt="" />
          </a>
        ))}
      </div>
    )}

    <div class="post-body" set:html={post.bodyHtml} />
  </article>

  {post.comments.length > 0 && (
    <section class="comments">
      <h2 class="comments-heading">{post.comments.length} comment{post.comments.length !== 1 ? 's' : ''}</h2>
      {post.comments.map(c => (
        <div class="comment">
          <div class="comment-meta">
            <span class="author">{c.author}</span>
            {c.authorHandle && <span class="handle">{c.authorHandle}</span>}
            <span class="cdate">{new Date(c.date).toLocaleString('en-GB')}</span>
          </div>
          {c.replyTo && (
            <div class="reply-quote">
              <span class="reply-author">{c.replyTo.author.replace(/-/g, ' ')}</span>
              <span class="reply-text">{c.replyTo.preview}</span>
            </div>
          )}
          <div class="comment-body" set:html={c.bodyHtml} />
          {c.images.length > 0 && (
            <div class="image-gallery small">
              {c.images.map(src => (
                <a href={src} target="_blank" rel="noopener">
                  <img src={src} loading="lazy" alt="" />
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </section>
  )}
</Layout>

<style>
  .breadcrumb {
    font-size: 0.8rem;
    color: #334155;
    margin-bottom: 0.75rem;
    font-family: ui-sans-serif, sans-serif;
  }
  .breadcrumb a { color: #475569; text-decoration: none; }
  .breadcrumb a:hover { color: #94a3b8; text-decoration: underline; }

  .post { margin-bottom: 2rem; }
  .post-body { max-width: 720px; font-size: 1.05rem; line-height: 1.7; color: #cbd5e1; font-family: inherit; }

  .post-body :global(p) { margin-bottom: 1em; }
  .post-body :global(a) { color: #60a5fa; }
  .post-body :global(a:hover) { color: #93c5fd; }
  .post-body :global(strong) { color: #e2e8f0; }
  .post-body :global(blockquote) {
    border-left: 3px solid #1e40af;
    background: #0f2547;
    border-radius: 0 6px 6px 0;
    padding: 0.5rem 0.9rem;
    margin: 0.75em 0;
    color: #93c5fd;
    font-size: 0.95em;
  }
  .post-body :global(blockquote p) { margin-bottom: 0; }

  .image-gallery {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .image-gallery img {
    max-width: min(560px, 100%);
    max-height: 560px;
    object-fit: contain;
    border-radius: 6px;
    border: 1px solid #1e293b;
    background: #0a0f1e;
  }
  .image-gallery.small img { max-width: min(320px, 100%); max-height: 320px; }

  .comments { max-width: 720px; }

  .comments-heading {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: #64748b;
    font-family: ui-sans-serif, sans-serif;
    border-top: 1px solid #1e293b;
    padding-top: 1rem;
  }

  .comment {
    margin-bottom: 1.25rem;
    padding-left: 1rem;
    border-left: 3px solid #1e293b;
  }

  .comment-meta {
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
    margin-bottom: 0.35rem;
    font-size: 0.8rem;
    font-family: ui-sans-serif, sans-serif;
  }

  .author { font-weight: 700; color: #94a3b8; }
  .handle { color: #334155; }
  .cdate { color: #1e293b; margin-left: auto; }

  .comment-body { font-size: 0.95rem; line-height: 1.6; color: #94a3b8; }
  .comment-body :global(p) { margin-bottom: 0.5em; }
  .comment-body :global(a) { color: #60a5fa; }
  .comment-body :global(blockquote) {
    border-left: 3px solid #1e3a5f;
    padding: 0.2em 0.75rem;
    margin: 0.4em 0 0.6em;
    color: #60a5fa;
    font-size: 0.9em;
    background: #0a1628;
    border-radius: 0 4px 4px 0;
  }
  .comment-body :global(blockquote p) { margin-bottom: 0; }

  .reply-quote {
    display: flex;
    flex-direction: column;
    border-left: 3px solid #1e3a5f;
    background: #0a1628;
    border-radius: 0 4px 4px 0;
    padding: 0.3rem 0.65rem;
    margin-bottom: 0.5rem;
    font-size: 0.82rem;
    font-family: ui-sans-serif, sans-serif;
  }
  .reply-author { font-weight: 700; color: #3b82f6; margin-bottom: 0.1rem; }
  .reply-text {
    color: #475569;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
