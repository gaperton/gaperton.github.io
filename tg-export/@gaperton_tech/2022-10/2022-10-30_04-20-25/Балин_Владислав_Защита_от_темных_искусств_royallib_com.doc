\s0 \qj\snext0\f1\fs24\b0\i0\fi567\li0\ri0 \fi0\li50\ri50 \i \b Strengths\b0  \i0   — \i \b Сильные стороны\b0   (свойства проекта или коллектива, дающие преимущества перед другими в отрасли)\i0  \b0\cell

\s0 \qj\snext0\f1\fs24\b0\i0\fi567\li0\ri0 \fi0\li50\ri50 \i \b Weaknesses\b0  \i0   — \i \b Слабые стороны\b0   (свойства, ослабляющие проект, недостатки)\i0  \b0\cell

}\row\trowd\trql\trftsWidth2\trwWidth5000\intbl
